datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  SUPPLIER
  CUSTOMER
}

enum PromotionType {
  CAMPAIGN
  PROMOCODE
}

enum PromotionDiscountType {
  PERCENT
  FIXED
}

enum PromotionScope {
  ORDER
  PRODUCT
  CATEGORY
}

model User {
  id         Int       @id @default(autoincrement())
  email      String    @unique
  password   String
  name       String?
  phone      String?
  address    String?
  role       Role      @default(CUSTOMER)
  supplierId Int?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  isBlocked  Boolean   @default(false)
  blockedAt  DateTime?
  orders     Order[]
  pageViews  PageView[]
  analyticsEvents AnalyticsEvent[]
  reviews    Review[]
  promotions Promotion[]
  bonusTransactions BonusTransaction[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @default(now()) @updatedAt
}

model Supplier {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  delivery String
  rating   Float     @default(5.0)
  reviews  Int       @default(0)
  products Product[]
  users    User[]
}

model Brand {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String
  logo        String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Product {
  id             Int         @id @default(autoincrement())
  name           String
  description    String?
  details        String?
  specifications String?
  usage          String?
  category       String
  price          Float
  oldPrice       Float?
  image          String
  rating         Float       @default(4.5)
  reviews        Int         @default(0)
  isHit          Boolean     @default(false)
  bulkDiscount   String?
  supplierId     Int
  supplier       Supplier    @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  orderItems     OrderItem[]
  analyticsEvents AnalyticsEvent[]
  categoryId     Int?
  categoryRelation Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  reviewsList    Review[]
}

model Category {
  id        Int        @id @default(autoincrement())
  name      String
  slug      String     @unique
  image     String?
  parentId  Int?
  parent    Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  Category[] @relation("CategoryHierarchy")
  products  Product[]
  createdAt DateTime   @default(now())
}

model Order {
  id              Int        @id @default(autoincrement())
  clientName      String
  clientPhone     String
  clientAddress   String
  paymentMethod   String
  status          String     @default("pending") // pending, processing, shipped, completed, cancelled
  subtotalAmount  Float      @default(0)
  discountAmount  Float      @default(0)
  totalAmount     Float
  promoCode       String?
  promotionTitle  String?
  promotionId     Int?
  promotionSnapshot Json?
  statusHistory  Json?
  promotion       Promotion? @relation(fields: [promotionId], references: [id], onDelete: SetNull)
  userId          Int?
  user            User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  cancellationReason String?
  managerNotes       String?
  usedBonusPoints    Float      @default(0)
  deliveryDate       String?
  deliveryTime       String?
  createdAt       DateTime   @default(now())
  items           OrderItem[]
  analyticsEvents AnalyticsEvent[]
  bonusTransactions BonusTransaction[]
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
}

model CallbackRequest {
  id        Int      @id @default(autoincrement())
  userName  String
  userPhone String
  comment   String?
  status    String   @default("pending") // pending, completed, rejected
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PartnerRequest {
  id           Int      @id @default(autoincrement())
  contactName  String
  companyName  String
  contactPhone String
  email        String
  comment      String?
  status       String   @default("pending") // pending, contacted, approved, rejected
  adminComment String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Promotion {
  id            Int                    @id @default(autoincrement())
  title         String
  description   String
  badge         String?
  promoCode     String?                @unique
  type          PromotionType          @default(CAMPAIGN)
  scope         PromotionScope         @default(ORDER)
  discountType  PromotionDiscountType
  discountValue Float
  minOrderAmount Float?
  minQuantity   Int?
  targetProductIds Int[]               @default([])
  targetCategoryIds Int[]              @default([])
  quantityTiers Json?
  theme         String                 @default("emerald")
  isActive      Boolean                @default(true)
  showOnSite    Boolean                @default(true)
  showOnHome    Boolean                @default(false)
  usageLimit    Int?
  usageCount    Int                    @default(0)
  startsAt      DateTime?
  endsAt        DateTime?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  orders        Order[]
  userId        Int?
  user          User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model PageView {
  id        Int      @id @default(autoincrement())
  path      String
  title     String?
  referrer  String?
  userAgent String?
  ip        String?
  sessionId String?
  region    String?
  country   String?
  city      String?
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([path])
  @@index([sessionId])
  @@index([userId])
}

model AnalyticsEvent {
  id          Int      @id @default(autoincrement())
  type        String
  path        String?
  sessionId   String?
  userId      Int?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  productId   Int?
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  orderId     Int?
  order       Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  searchQuery String?
  value       Float?
  metadata    Json?
  userAgent   String?
  ip          String?
  region      String?
  country     String?
  city        String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([type])
  @@index([sessionId])
  @@index([userId])
  @@index([productId])
  @@index([orderId])
  @@index([searchQuery])
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model Review {
  id         Int      @id @default(autoincrement())
  rating     Int      // Оценка от 1 до 5
  comment    String?  @db.Text
  productId  Int
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@unique([userId, productId]) // Один отзыв на один товар от одного пользователя
}

model BonusTransaction {
  id          Int       @id @default(autoincrement())
  userId      Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId     Int?
  order       Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)
  type        String    // "earned" | "spent" | "manual" | "cancelled"
  status      String    // "pending" | "available" | "used" | "cancelled"
  amount      Float     // сумма бонусов (всегда положительная)
  description String?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([orderId])
  @@index([status])
  @@index([type])
  @@index([userId, status])
}
