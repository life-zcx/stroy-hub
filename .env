# Database configuration (for postgres container)
POSTGRES_USER=stroyhub_user
POSTGRES_PASSWORD=stroyhub_secure_pass
POSTGRES_DB=stroyhub
POSTGRES_PORT=5432

# Connection string for Prisma/Backend (uses 'db' service name inside docker-compose)
DATABASE_URL=postgresql://stroyhub_user:stroyhub_secure_pass@db:5432/stroyhub?schema=public

# Local connection string (if running backend outside Docker, connecting to localhost:5432)
# DATABASE_URL=postgresql://stroyhub_user:stroyhub_secure_pass@localhost:5432/stroyhub?schema=public

# Server configurations
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
